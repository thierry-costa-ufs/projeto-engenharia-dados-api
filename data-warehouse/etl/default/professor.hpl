  <transform>
    <type>TableInput</type>
    <name>Origem Professor Banco</name>
    <sql>SELECT 
    p.mat_professor AS mat_prof_banco,
    UPPER(u.nome) AS nome_banco,
    p.tipo_jornada_trabalho AS jornada_banco,
    p.formacao AS formacao_banco,
    p.departamento AS depto_banco
FROM universidade.professor p
JOIN universidade.usuario u ON p.cpf = u.cpf;</sql>
    <limit>0</limit>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
