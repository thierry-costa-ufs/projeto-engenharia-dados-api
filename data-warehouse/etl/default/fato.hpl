  <transform>
    <type>TableInput</type>
    <name>Table input</name>
    <sql>SELECT 
    t.id_turma,
    t.numero AS numero_turma,
    d.depto_responsavel AS cod_depto,
    t.cod_disc,
    UPPER(u.nome) AS nome_professor,
    t.ano,
    t.semestre,
    COUNT(c.mat_estudante) AS total_discentes,
    ROUND(AVG(c.nota)::numeric, 2) AS media_notas,
    COUNT(CASE WHEN c.nota >= 5.0 THEN 1 END) AS aprovados,
    COUNT(CASE WHEN c.nota &lt; 5.0 THEN 1 END) AS reprovados
FROM universidade.turma t
INNER JOIN universidade.disciplina d ON t.cod_disc = d.cod_disc
INNER JOIN universidade.leciona l ON t.id_turma = l.id_turma
INNER JOIN universidade.professor p ON l.mat_professor = p.mat_professor 
INNER JOIN universidade.usuario u ON p.cpf = u.cpf                       
LEFT JOIN universidade.cursa c ON t.id_turma = c.id_turma
GROUP BY 
    t.id_turma,
    t.numero,
    d.depto_responsavel, 
    t.cod_disc, 
    u.nome,
    t.ano, 
    t.semestre;</sql>
    <limit>0</limit>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <connection>engdados_db</connection>
    <lookup/>
    <sql_from_file/>
    <distribute>Y</distribute>
    <copies>1</copies>
    <GUI>
      <xloc>112</xloc>
      <yloc>160</yloc>
    </GUI>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <attributes/>
  </transform>
